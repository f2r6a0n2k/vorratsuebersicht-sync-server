<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Vorratsuebersicht.Desktop"
             x:Class="Vorratsuebersicht.Desktop.App">
  <Application.Resources>
    <local:BoolToBrushConverter x:Key="ToBrush"/>
    <local:InverseBoolConverter x:Key="Not"/>
    <local:StringNotEmptyConverter x:Key="HasText"/>
    <local:BoolToOpacityConverter x:Key="ToOpacity"/>
    <local:BoolToTextDecorationsConverter x:Key="ToTextDecorations"/>
    <local:BoolToConnectTextConverter x:Key="ConnectText"/>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
  </Application.Styles>
</Application>
