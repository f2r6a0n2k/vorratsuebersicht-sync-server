<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Vorratsuebersicht.Desktop.Views.ShoppingListView">
  <DockPanel>
    <Border DockPanel.Dock="Top" Padding="12 8">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Command="{Binding ShowFormCommand}" Content="+ Neu"/>
        <Button Command="{Binding LoadCommand}" Content="Aktualisieren"/>
      </StackPanel>
    </Border>

    <ScrollViewer>
      <ListBox ItemsSource="{Binding Items}" IsVisible="{Binding ShowAddForm, Converter={StaticResource Not}}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Padding="8" Margin="4 2"
                    Opacity="{Binding IsChecked, Converter={StaticResource ToOpacity}}">
              <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <CheckBox IsChecked="{Binding IsChecked}" IsEnabled="False"/>
                <StackPanel Grid.Column="1">
                  <TextBlock Text="{Binding ArticleName}" FontWeight="SemiBold"
                             TextDecorations="{Binding IsChecked, Converter={StaticResource ToTextDecorations}}"/>
                  <TextBlock Text="{Binding Quantity, StringFormat=Menge: {0}}" FontSize="12"/>
                </StackPanel>
                <Button Grid.Column="2" Command="{Binding $parent[ListBox].DataContext.ToggleItemCommand}"
                        CommandParameter="{Binding}" Content="&#x2713;" Width="32" Background="#27ae60"/>
                <Button Grid.Column="3" Command="{Binding $parent[ListBox].DataContext.DeleteItemCommand}"
                        CommandParameter="{Binding}" Content="&#x2716;" Width="32" Background="#e74c3c"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </ScrollViewer>

    <Border IsVisible="{Binding ShowAddForm}" Padding="16">
      <StackPanel Spacing="8" Width="400">
        <TextBlock Text="Neuer Einkaufszettel-Eintrag" FontSize="16" FontWeight="Bold"/>
        <ComboBox ItemsSource="{Binding Articles}" PlaceholderText="Artikel wählen...">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBox Text="{Binding NewItem.Quantity}" Watermark="Menge"/>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
          <Button Command="{Binding CancelFormCommand}" Content="Abbrechen"/>
          <Button Command="{Binding SaveItemCommand}" Content="Speichern" Background="#27ae60"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" IsVisible="{Binding IsLoading}">
      <ProgressBar IsIndeterminate="True" Height="4"/>
    </Border>
  </DockPanel>
</UserControl>
