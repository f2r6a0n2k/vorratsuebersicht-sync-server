<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Vorratsuebersicht.Desktop.Views"
        x:Class="Vorratsuebersicht.Desktop.Views.MainWindow"
        Title="{Binding Title}"
        Width="960" Height="680"
        MinWidth="640" MinHeight="480">
  <Grid RowDefinitions="Auto,*">
    <Border Background="#2c3e50" Padding="12 8">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBlock Text="Vorrats&#xfc;bersicht" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
          <Border Background="{Binding IsConnected, Converter={StaticResource ToBrush}}" 
                  CornerRadius="4" Padding="6 2" VerticalAlignment="Center">
            <TextBlock Text="{Binding ServerStatus}" FontSize="12" Foreground="White"/>
          </Border>
        </StackPanel>
        <TabControl Grid.Column="1" BorderThickness="0" Background="Transparent"
                    SelectedIndex="{Binding SelectedTab}">
          <TabItem Header="Artikel"/>
          <TabItem Header="Lager"/>
          <TabItem Header="Einkauf"/>
          <TabItem Header="Einstellungen"/>
        </TabControl>
      </Grid>
    </Border>

    <Carousel Grid.Row="1" SelectedIndex="{Binding SelectedTab}">
      <views:ArticleListView DataContext="{Binding Articles}"/>
      <views:StorageListView DataContext="{Binding Storage}"/>
      <views:ShoppingListView DataContext="{Binding Shopping}"/>
      <views:SettingsView DataContext="{Binding Settings}"/>
    </Carousel>
  </Grid>
</Window>
