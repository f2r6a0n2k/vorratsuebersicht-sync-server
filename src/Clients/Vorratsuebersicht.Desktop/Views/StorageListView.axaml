<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Vorratsuebersicht.Desktop.Views.StorageListView">
  <DockPanel>
    <Border DockPanel.Dock="Top" Padding="12 8">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Command="{Binding ShowFormCommand}" Content="+ Zugang"/>
        <Button Command="{Binding LoadCommand}" Content="Aktualisieren"/>
      </StackPanel>
    </Border>

    <ScrollViewer>
      <ListBox ItemsSource="{Binding Items}" IsVisible="{Binding ShowEntryForm, Converter={StaticResource Not}}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Padding="8" Margin="4 2">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                  <TextBlock Text="{Binding ArticleName}" FontWeight="SemiBold"/>
                  <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="{Binding Quantity, StringFormat=Menge: {0}}" FontSize="12"/>
                    <TextBlock Text="{Binding BestBeforeDate, StringFormat=MHD: {0}}" FontSize="12" Foreground="#666"/>
                    <TextBlock Text="{Binding StorageName}" FontSize="12" Foreground="#666"/>
                  </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding $parent[ListBox].DataContext.DeleteItemCommand}"
                        CommandParameter="{Binding}" Content="&#x2716;" Width="32" Background="#e74c3c"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </ScrollViewer>

    <Border IsVisible="{Binding ShowEntryForm}" Padding="16">
      <StackPanel Spacing="8" Width="400">
        <TextBlock Text="Neuer Lagerzugang" FontSize="16" FontWeight="Bold"/>
        <ComboBox ItemsSource="{Binding Articles}" PlaceholderText="Artikel wählen...">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBox Text="{Binding NewItem.Quantity}" Watermark="Menge"/>
        <TextBox Text="{Binding NewItem.BestBeforeDate}" Watermark="MHD (JJJJ-MM-TT)"/>
        <TextBox Text="{Binding NewItem.StorageName}" Watermark="Lagername"/>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
          <Button Command="{Binding CancelFormCommand}" Content="Abbrechen"/>
          <Button Command="{Binding SaveItemCommand}" Content="Speichern" Background="#27ae60"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" IsVisible="{Binding IsLoading}">
      <ProgressBar IsIndeterminate="True" Height="4"/>
    </Border>
  </DockPanel>
</UserControl>
